# HR Portal – Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hr_user:changeme@localhost:5432/hr_portal

# Pool settings (ignored when DB_NULLPOOL=true)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Set to true in test / serverless environments
DB_NULLPOOL=false

# ── FastAPI ───────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=true
